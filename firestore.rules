rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.profile is map &&
             data.stats is map &&
             data.achievements is list &&
             data.settings is map &&
             (!data.keys().contains('completedLessons') || data.completedLessons is list) &&
             (!data.keys().contains('dailyChallenges') || data.dailyChallenges is list) &&
             (!data.keys().contains('lastSynced') || data.lastSynced is string);
    }

    function isValidLeaderboardEntry(data) {
      return data.userId is string && data.userId.size() <= 128 &&
             data.name is string && data.name.size() <= 100 &&
             data.bestWpm is number && data.bestWpm >= 0 && data.bestWpm <= 500 &&
             data.accuracy is number && data.accuracy >= 0 && data.accuracy <= 100 &&
             (!data.keys().contains('avatar') || data.avatar is string) &&
             (!data.keys().contains('level') || data.level is number) &&
             (!data.keys().contains('kb') || data.kb is string) &&
             (!data.keys().contains('layout') || data.layout is string) &&
             (!data.keys().contains('country') || data.country is string) &&
             (!data.keys().contains('updatedAt') || data.updatedAt is string);
     }

    function isValidParagraph(data) {
      return data.id is string &&
             data.title is string && data.title.size() <= 200 &&
             data.category is string &&
             data.difficulty is string &&
             data.wordCount is number &&
             data.estimatedTime is number &&
             data.language is string &&
             data.tags is list &&
             data.createdAt is number &&
             data.content is string;
    }

    // Match blocks
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      allow delete: if isOwner(userId);
    }

    match /leaderboard/{leaderboardId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && isValidLeaderboardEntry(incoming()) && isValidId(leaderboardId);
      allow update: if isSignedIn() && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && isValidLeaderboardEntry(incoming()) && isValidId(leaderboardId);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid && isValidId(leaderboardId);
    }

    match /paragraphs/{paragraphId} {
      allow read: if true;
      allow create, update: if isSignedIn() && isValidParagraph(incoming()) && isValidId(paragraphId);
      allow delete: if false;
    }

    match /beta_feedback/{feedbackId} {
      allow read, write: if true;
    }

    match /paragraph_reports/{reportId} {
      allow read, write: if true;
    }
  }
}
